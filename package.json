{
  "name": "umashinbun",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "毎朝、競馬ニュースを翻訳・要約して『レースごと・馬ごと・種牡馬ごと』に集約するダイジェスト",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "fetch": "node --experimental-strip-types scripts/fetch-feeds.ts",
    "fetch-article": "node --experimental-strip-types scripts/fetch-article.ts",
    "fetch-runners": "node --experimental-strip-types scripts/fetch-runners.ts",
    "today-mode": "node --experimental-strip-types scripts/today-mode.ts",
    "ingest": "node --experimental-strip-types scripts/ingest.ts",
    "build-races": "node --experimental-strip-types scripts/build-races.ts",
    "build-horses-sires": "node --experimental-strip-types scripts/build-horses-sires.ts",
    "build-entities": "node --experimental-strip-types scripts/build-entities.ts",
    "build-md": "node --experimental-strip-types scripts/build-markdown.ts",
    "build": "npm run build-races && npm run build-horses-sires && npm run build-entities && npm run build-md",
    "query": "node --experimental-strip-types scripts/query.ts"
  }
}
